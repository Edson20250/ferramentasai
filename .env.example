# ============================================================
# FERRAMENTASAI — Variáveis de Ambiente
# Copia este ficheiro para .env.local e preenche os valores
# ============================================================

# Base de dados (Supabase)
# Vai a: supabase.com → o teu projeto → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# URL pública do site
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# Em produção: NEXT_PUBLIC_BASE_URL="https://ferramentasai.pt"

# Stripe (pagamentos)
# Vai a: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (produção — cria produtos/preços no dashboard Stripe)
# Se vazios, o checkout usa price_data (montantes em centimos) para desenvolvimento
STRIPE_PRICE_ID_BASICO=""
STRIPE_PRICE_ID_PRO=""
STRIPE_PRICE_ID_DESTAQUE=""

# Área admin (/admin, /api/admin/*): define um segredo longo; login em /admin/login
ADMIN_SECRET=""

# Cron Vercel / chamada manual: GET /api/cron/deactivate-expired com Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# Newsletter Beehiiv (opcional — só precisas quando tiveres subscritores)
# Vai a: app.beehiiv.com → Settings → API
BEEHIIV_API_KEY=""
BEEHIIV_PUBLICATION_ID=""

# NextAuth (para admin — opcional no MVP)
NEXTAUTH_SECRET="gera-um-segredo-aleatorio-aqui"
NEXTAUTH_URL="http://localhost:3000"
